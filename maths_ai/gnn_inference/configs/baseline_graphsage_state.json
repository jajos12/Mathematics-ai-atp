{
  "prepared_root": "artifacts/prepared/v1",
  "run_root": "runs/baseline_gnn",
  "seed": 42,
  "device": "auto",
  "edge_mode": "bidirectional",
  "use_node_type": true,
  "model": {
    "hidden_dim": 512,
    "num_layers": 4,
    "dropout": 0.2
  },
  "training": {
    "batch_size": 256,
    "epochs": 20,
    "learning_rate": 0.001,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "log_every_batches": 100,
    "num_workers": 12,
    "pin_memory": true,
    "persistent_workers": true,
    "prefetch_factor": 2,
    "use_amp": true
  }
}
