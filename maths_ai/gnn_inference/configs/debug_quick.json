{
  "experiment_name": "debug_quick",
  "stages": ["baseline", "pointer"],
  "prepared_root": "maths_ai/gnn_inference/artifacts/prepared/v1",
  "run_root": "maths_ai/gnn_inference/runs",

  "prepare": {
    "dataset_name": "cat-searcher/leandojo-benchmark-4-random",
    "splits": "train,val,test",
    "sample_per_split": null,
    "force": false
  },

  "baseline": {
    "hidden_dim": 128,
    "num_layers": 2,
    "dropout": 0.1,
    "batch_size": 64,
    "epochs": 5,
    "learning_rate": 0.003,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "num_workers": 4,
    "use_amp": true
  },

  "pointer": {
    "hidden_dim": 128,
    "num_layers": 2,
    "dropout": 0.1,
    "max_args": 3,
    "arg_loss_weight": 0.5,
    "batch_size": 64,
    "epochs": 5,
    "learning_rate": 0.003,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "num_workers": 4,
    "use_amp": true
  },

  "scorer": {
    "premise_config": "maths_ai/gnn_inference/configs/premise_scoring.json",
    "hidden_dim": 128,
    "num_layers": 2,
    "dropout": 0.1,
    "batch_size": 64,
    "epochs": 5,
    "learning_rate": 0.003,
    "weight_decay": 0.0001,
    "grad_clip": 1.0,
    "num_workers": 4,
    "use_amp": true,
    "k": 5,
    "premise_loss_weight": 1.0,
    "scoring_mode": "dot"
  },

  "seed": 42,
  "device": "auto"
}
